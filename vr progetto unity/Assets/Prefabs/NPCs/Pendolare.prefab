  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 34cdae2f98a5d4434bcf01efa7a386d4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  dialogue:
  - frasi:
    - clip: {fileID: 8300000, guid: 4fb4e58b07e10c24586d48b1e0efb27e, type: 3}
      text: "Finalmente qualcuno. C'\xE8 stato un gran trambusto poco fa."
    - clip: {fileID: 8300000, guid: 6bbaa55a35b6db34cb386ea1de448e7a, type: 3}
      text: Ho sentito un colpo poi delle urla, ho paura sia successo qualcosa ad
        un passeggero.
    - clip: {fileID: 8300000, guid: aa084eebcb5d07047b0843b599391b46, type: 3}
      text: " Forse era il signor Thomas Briggs, ma non ne sono certo, purtroppo
        per\xF2 non ho visto chi sia stato il colpevole. Meglio che qualcuno indaghi."
    puzzles: []
    delay:
      time: 1
      index: 0
    itemToAnnotateAfterDialog: 
    progressToUnlockAfterDialog: 4
  - frasi:
    - clip: {fileID: 8300000, guid: eebede79bb97044a2b60990e5e6005f7, type: 3}
      text: Buonasera Ispettore
    puzzles: []
    delay:
      time: 0
      index: 0
    itemToAnnotateAfterDialog: 
    progressToUnlockAfterDialog: 4
  source: {fileID: 0}
  animator: {fileID: 0}
  nextScene: 
