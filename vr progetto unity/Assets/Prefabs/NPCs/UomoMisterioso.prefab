--- !u!114 &-2282993837038460264
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6392765374730372224}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 34cdae2f98a5d4434bcf01efa7a386d4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  dialogue:
  - frasi:
    - clip: {fileID: 8300000, guid: 585e1069b9a4242c490782ae5542d686, type: 3}
      text: "Un uomo, prima del terribile accaduto, \xE8 entrato nella cabina del
        presunto morto."
    - clip: {fileID: 8300000, guid: 3aff084c7c9ec43d88db2f7568bd8517, type: 3}
      text: ' Indossava un cappello di castoro nero.'
    - clip: {fileID: 8300000, guid: d0032b06ac5f341f7831fa05fcdb3891, type: 3}
      text: " Non era uno qualunque \u2026 aveva un\u2019aria tenebrosa"
    - clip: {fileID: 8300000, guid: c6ab0239e6e93488b8b9c8129c1e3316, type: 3}
      text: "magari \xE8 stato proprio lui a commettere l\u2019omicidio."
    - clip: {fileID: 8300000, guid: a6100925c511240a7bf9a56a4a9d0078, type: 3}
      text: Secondo me nella cabina potrebbero esserci ulteriori indizi
    puzzles: []
    delay:
      time: 1
      index: 0
    itemToAnnotateAfterDialog: 05000000
    progressToUnlockAfterDialog: 3
  - frasi:
    - clip: {fileID: 8300000, guid: a6100925c511240a7bf9a56a4a9d0078, type: 3}
      text: Secondo me nella cabina potrebbero esserci ulteriori indizi
    puzzles: []
    delay:
      time: 0
      index: 0
    itemToAnnotateAfterDialog: 
    progressToUnlockAfterDialog: 4
