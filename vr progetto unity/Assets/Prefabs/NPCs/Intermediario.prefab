--- !u!114 &2459888462268870720
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7741398001145973752}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 34cdae2f98a5d4434bcf01efa7a386d4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  dialogue:
  - frasi:
    - clip: {fileID: 8300000, guid: 66ac3986884cd90458b3ee4d4c516926, type: 3}
      text: "Aspetti.   Quel cappello\u2026 lo riconosco."
    - clip: {fileID: 8300000, guid: ff3006490933f7d4d99fc3a1b1b66fd8, type: 3}
      text: "L\u2019ho comprato io. Non per me. Un certo\u2026 Franz M\xFCller mi
        ha commissionato di prenderglielo. Mi ha pagato molto per farlo, sinceramente
        non capivo per quale motivo \u2026forse voleva che la sua identit\xE0 rimanesse
        segreta, ma non so cosa avesse da nascondere."
    puzzles: []
    delay:
      time: 1
      index: 0
    itemToAnnotateAfterDialog: 
    progressToUnlockAfterDialog: 4
  source: {fileID: 0}
  animator: {fileID: 0}
  nextScene: OutroScene
  dialogueId: 5
