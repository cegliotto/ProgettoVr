    - target: {fileID: 3103436858856514575, guid: 59579ee2c93d5774c8e930f0ea862ff2, type: 3}
      propertyPath: dialogueId
      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 3103436858856514575, guid: 59579ee2c93d5774c8e930f0ea862ff2, type: 3}
      propertyPath: dialogue.Array.data[0].frasi.Array.size
      value: 3
      objectReference: {fileID: 0}
    - target: {fileID: 3103436858856514575, guid: 59579ee2c93d5774c8e930f0ea862ff2, type: 3}
      propertyPath: dialogue.Array.data[0].frasi.Array.data[0].clip
      value: 
      objectReference: {fileID: 8300000, guid: 4fb4e58b07e10c24586d48b1e0efb27e, type: 3}
    - target: {fileID: 3103436858856514575, guid: 59579ee2c93d5774c8e930f0ea862ff2, type: 3}
      propertyPath: dialogue.Array.data[0].frasi.Array.data[0].text
      value: "Finalmente qualcuno. C'\xE8 stato un gran trambusto poco fa."
      objectReference: {fileID: 0}
    - target: {fileID: 3103436858856514575, guid: 59579ee2c93d5774c8e930f0ea862ff2, type: 3}
      propertyPath: dialogue.Array.data[0].frasi.Array.data[1].clip
      value: 
      objectReference: {fileID: 8300000, guid: 6bbaa55a35b6db34cb386ea1de448e7a, type: 3}
    - target: {fileID: 3103436858856514575, guid: 59579ee2c93d5774c8e930f0ea862ff2, type: 3}
      propertyPath: dialogue.Array.data[0].frasi.Array.data[1].text
      value: Ho sentito un colpo poi delle urla, ho paura sia successo qualcosa ad
        un passeggero.
      objectReference: {fileID: 0}
    - target: {fileID: 3103436858856514575, guid: 59579ee2c93d5774c8e930f0ea862ff2, type: 3}
      propertyPath: dialogue.Array.data[0].frasi.Array.data[2].clip
      value: 
      objectReference: {fileID: 8300000, guid: aa084eebcb5d07047b0843b599391b46, type: 3}
    - target: {fileID: 3103436858856514575, guid: 59579ee2c93d5774c8e930f0ea862ff2, type: 3}
      propertyPath: dialogue.Array.data[0].frasi.Array.data[2].text
      value: " Forse era il signor Thomas Briggs, ma non ne sono certo, purtroppo
        per\xF2 non ho visto chi sia stato il colpevole. Meglio che qualcuno indaghi."
      objectReference: {fileID: 0}
    - target: {fileID: 9199731121875895752, guid: 59579ee2c93d5774c8e930f0ea862ff2, type: 3}
      propertyPath: puzzle
      value: 
      objectReference: {fileID: 998808340}
    - target: {fileID: 9199731121875895752, guid: 59579ee2c93d5774c8e930f0ea862ff2, type: 3}
      propertyPath: sittingTransform
      value: 
      objectReference: {fileID: 525171976}
