  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5a7980fe2e2c69a4b819190e627ae11b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::WordByWordText
  textComponent: {fileID: 1698775319}
  fullText: 'On 9 July 1864, on the evening train of the North London Railway, the
    first murder ever to occur on a British railway took place. The victim was Thomas
    Briggs, a respectable bank clerk.  His train ticket, found and recognised, confirmed
    his presence on board that evening. Also found alongside the blood were a stick
    and a bag, both identified as Briggs'' property. However, some valuable objects
    were missing: a watch, a gold chain and some gold glasses, later traced thanks
    to the words of a witness. Shortly afterwards, in the cabin of the murder train,
    a black beaver hat was found, later found to belong to Franz Muller, who had
    commissioned its purchase to a woman from London, a crucial witness in solving
    the case. This hat became the decisive clue. All the evidence led to Franz Muller,
    who was arrested, tried and found guilty of the murder of Thomas Briggs.'
  charDelay: 0.03
  cluePause: 2
  clues:
  - train ticket,
  - stick
  - bag,
  - watch,
  - gold chain
  - gold glasses,
  - black beaver hat
  clueObjects:
  - {fileID: 1816674529}
  - {fileID: 2084177086}
  - {fileID: 50740555}
  - {fileID: 1609422921}
  - {fileID: 499763493}
  - {fileID: 56962954}
  - {fileID: 939797787}
  animationDuration: 0.8
  pulseScale: {x: 1.2, y: 1.2, z: 1.2}
  hoverAmplitude: 0.1
  hoverSpeed: 2
  continueButton: {fileID: 748419247}
  buttonCanvasGroup: {fileID: 748419253}
  buttonDelay: 1
  fadeDuration: 0.5
